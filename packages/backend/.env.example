# Backend Environment
# Copy to .env and fill in values

# Solana RPC (devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Risk authority keypair (base58 encoded secret key)
# Generate with: solana-keygen new --outfile risk-authority.json
# Then encode: node -e "console.log(require('bs58').default.encode(require('fs').readFileSync('risk-authority.json')))"
RISK_AUTHORITY_SECRET_KEY=

# Program ID (update after anchor build)
PROGRAM_ID=9Z6HNGC1wz6ukVCD3qNqnfFMDfCffNPBz6dG5k8fakHc

# Server
PORT=3001

# AI provider
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
AI_TIMEOUT_MS=3000
GEMINI_MODEL=gemini-1.5-flash

# Firebase token forwarding placeholder
# Frontend can attach Firebase ID token as Authorization: Bearer <token>
# Backend currently stores/forwards this context but does not enforce verification yet

# Listener poll interval for pending spend requests
RISK_POLL_INTERVAL_MS=12000
